### Sitemap (/sitemap.ts)
```ts
export default async function sitemap(): Promise<MetadataRoute.Sitemap> {
  const posts = await prisma.post.findMany({ where: { status: 'PUBLISHED' } })
  return [
    { url: 'https://panrybka.pl', lastModified: new Date(), priority: 1.0 },
    { url: 'https://panrybka.pl/sprzet-wedkarski', priority: 0.8 },
    { url: 'https://panrybka.pl/poradniki', priority: 0.8 },
    { url: 'https://panrybka.pl/miejsca', priority: 0.8 },
    ...posts.map(p => ({
      url: `https://panrybka.pl/${categoryToPath(p.category)}/${p.slug}`,
      lastModified: p.updatedAt,
      priority: 0.7,
    }))
  ]
}
```
 
