## PRISMA SCHEMA
 
```prisma
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
 
generator client {
  provider = "prisma-client-js"
}
 
enum PostCategory {
  SPRZET
  PORADNIK
  MIEJSCA
}
 
enum PostStatus {
  DRAFT
  PUBLISHED
}
 
enum SchemaType {
  Article
  HowTo
  Review
}
 
model Post {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  excerpt         String
  content         String       @db.Text
  category        PostCategory
  status          PostStatus   @default(DRAFT)
  featuredImage   String?
  author          String       @default("Redakcja PanRybka")
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  schemaType      SchemaType   @default(Article)
  focusKeyword    String?
  publishedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  products        PostProduct[]
}
 
model Product {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  brand            String
  category         String
  description      String       @db.Text
  imageUrl         String?
  affiliateUrl     String
  affiliateNetwork String       @default("Amazon")
  price            Float?
  priceUpdatedAt   DateTime?
  rating           Float        @default(0)
  pros             String[]
  cons             String[]
  specs            Json
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  posts            PostProduct[]
}
 
model PostProduct {
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  position  Int      @default(0)
  isWinner  Boolean  @default(false)
 
  @@id([postId, productId])
}
 
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}
```
 
