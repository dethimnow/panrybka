### Upload zdjęć (API route /api/upload)
```ts
// Przyjmuje FormData z plikiem
// Konwertuje do WebP przez sharp (npm install sharp)
// Uploaduje do Supabase Storage bucket "images"
// Zwraca publiczny URL
const { data } = await supabase.storage
  .from('images')
  .upload(`posts/${slug}-${Date.now()}.webp`, webpBuffer, {
    contentType: 'image/webp', upsert: true
  })
const { data: urlData } = supabase.storage.from('images').getPublicUrl(data.path)
return { url: urlData.publicUrl }
```
 
